# ── Supabase ────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ── Stripe (usar chaves live para produção) ─────────────────────
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...

# ── Resend (email) ──────────────────────────────────────────────
RESEND_API_KEY=re_...

# ── App ─────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=https://recibocerto.pt

# ── SEO / verificação de propriedade (ver docs/SEO.md) ──────────
# Código de verificação do Google Search Console (método "tag HTML").
# Cola só o valor do content="..." da meta tag fornecida pelo Google.
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
# Código de verificação do Bing Webmaster Tools (meta msvalidate.01).
NEXT_PUBLIC_BING_SITE_VERIFICATION=
